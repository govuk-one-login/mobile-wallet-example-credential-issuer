{
  "compilerOptions": {
    "rootDir": ".",
    "target": "es2025",
    "lib": ["esnext"],
    "strict": true,
    "preserveConstEnums": true,
    "noEmit": true,
    "sourceMap": true,
    "module": "ESNext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "jest"]
  },
  "exclude": ["node_modules"],
  "include": ["src", "test"]
}
