{
  "name": "mobile-wallet-cri-test-harness",
  "version": "1.0.0",
  "description": "A service for testing a Wallet credential issuer",
  "author": "",
  "license": "MIT",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "execute": "node ./dist/src/server.js",
    "lint": "eslint . ",
    "lint:fix": "eslint . --fix",
    "format": "prettier --ignore-path .gitignore --write \"*/**/*.{ts,json}\"",
    "format:check": "node_modules/.bin/prettier --check .",
    "format:fix": "prettier --ignore-path .gitignore --write \"*/**/*.{ts,json}\"",
    "test": "node_modules/.bin/jest --testPathPatterns=test/credential-issuer-tests.test.ts --coverage=false",
    "test:unit": "TZ=UTC jest --testPathPatterns='test/helpers|src' --silent"
  },
  "dependencies": {
    "@peculiar/x509": "^2.0.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.18.0",
    "bs58": "^6.0.0",
    "cbor2": "^2.3.0",
    "ecdsa-sig-formatter": "^1.0.11",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
