{
  "name": "mobile-wallet-document-builder",
  "version": "1.0.0",
  "type": "module",
  "description": "A service for filling in the content of documents, storing them and, through integration with a wallet credential issuer, providing the links needed to load those documents into the GOV.UK Wallet",
  "repository": "https://github.com/govuk-one-login/mobile-wallet-example-credential-issuer",
  "scripts": {
    "build": "npm run typecheck && npm run build:esbuild && npm run build-sass && npm run copy-scripts && npm run copy-templates && npm run copy-govuk-assets && npm run copy-jsontree && npm run copy-resources",
    "build:esbuild": "esbuild src/server.ts --bundle --platform=node --format=esm --outfile=dist/server.js --packages=external --sourcemap",
    "build-sass": "rm -rf dist/public/style.css && sass --no-source-map src/assets/scss/application.scss dist/public/stylesheets/application.css --style compressed",
    "checkov": "checkov -f deploy/template.yaml",
    "copy-scripts": "rm -r dist/public/scripts || true && mkdir -p dist/public/scripts && cp node_modules/govuk-frontend/dist/govuk/govuk-frontend.min.js dist/public/scripts",
    "copy-templates": "mkdir -p dist && copyfiles -u 1 'src/**/*.njk' dist/",
    "copy-govuk-assets": "rm -rf dist/assets && cp -rf node_modules/govuk-frontend/dist/govuk/assets dist/assets",
    "copy-jsontree": "cp node_modules/jjsontree.js/dist/jsontree.js dist/assets/ && cp node_modules/jjsontree.js/dist/jsontree.js.css dist/assets",
    "copy-resources": "copyfiles -u 2 'src/resources/*' dist/resources/",
    "dev": "nodemon -e js,ts,njk --watch src --exec \"npm run build && npm run start\"",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "test": "node_modules/.bin/jest",
    "test:cov": "jest --coverage",
    "lint": "eslint . ",
    "lint:fix": "eslint . --fix",
    "format": "prettier --ignore-path .gitignore --write \"*/**/*.{ts,json}\"",
    "format:check": "prettier --ignore-path .gitignore --check \"*/**/*.{ts,json}\"",
    "localAws:up": "docker compose -f docker-compose.yml up --build -d --wait",
    "localAws:down": "docker compose -f docker-compose.yml down"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@auth0/cose": "^1.0.2",
    "@auth0/mdl": "^3.0.1",
    "@aws-sdk/client-dynamodb": "^3.1085.0",
    "@aws-sdk/client-kms": "^3.1085.0",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/lib-dynamodb": "^3.1085.0",
    "axios": "^1.18.1",
    "bs58": "^6.0.0",
    "cbor2": "^2.3.0",
    "cookie-parser": "^1.4.7",
    "copyfiles": "2.4.1",
    "ecdsa-sig-formatter": "^1.0.11",
    "express": "^5.2.1",
    "govuk-frontend": "^6.3.0",
    "jjsontree.js": "^4.7.1",
    "jose": "^5.10.0",
    "nunjucks": "3.2.4",
    "openid-client": "^5.6.5",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest-mock/express": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/nunjucks": "^3.2.6",
    "@types/qrcode": "^1.5.6",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-jest": "^4.1.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "nodemon": "3.1.14",
    "prettier": "^3.9.5",
    "sass": "^1.101.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.63.0"
  }
}
